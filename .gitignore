# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# vendored swagger-ui assets — regenerated from the locked swagger-ui-dist
# version by the prebuild/predev hooks (scripts/copy-swagger.mjs).
/public/vendor/swagger-ui/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets. Keep the example tracked so forkers
# can see which variables the app expects.
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# superpowers — internal design docs & workflow scratch, not part of the repo
docs/superpowers/
.superpowers/
