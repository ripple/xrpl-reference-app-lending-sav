# XRPL Network — Devnet is the only network where XLS-66/65 are enabled
# at the time of writing. Swap to testnet/mainnet once the amendments activate.
XRPL_NETWORK_URL=wss://s.devnet.rippletest.net:51233/
XRPL_FAUCET_URL=https://faucet.devnet.rippletest.net/accounts

# SourceTag stamped on every transaction this app submits, so its on-chain
# activity can be filtered/analyzed later. Optional — leave unset to omit it.
# Must be a 32-bit unsigned integer (0 – 4294967295).
XRPL_SOURCE_TAG=

# MongoDB — required at request time only (build does not connect).
# Replace with an Atlas connection string in production.
MONGODB_URI=mongodb://localhost:27017/xls66-lending

# Wallet secret encryption — 32-byte key, base64. REQUIRED.
# Encrypts wallet `seed` and `privateKey` at rest in MongoDB; they are
# decrypted server-side only when signing. Generate with: openssl rand -base64 32
WALLET_ENCRYPTION_KEY=

# CSP violation reports — optional. Defaults to the in-app /api/csp-report
# collector (logged server-side). Override only to point at an external
# reporting service. Example: CSP_REPORT_URI=https://csp.example.com/report
CSP_REPORT_URI=

# Public site URL — used in OpenGraph tags, sitemap, robots.txt.
# Leave unset for local development; set to the production origin on Vercel.
# Example: NEXT_PUBLIC_SITE_URL=https://xls66.example.com
NEXT_PUBLIC_SITE_URL=

# Auth0 — required for authentication.
# Generate AUTH0_SECRET with: openssl rand -hex 32
# Dashboard: https://manage.auth0.com → Applications → <your app> → Settings
AUTH0_SECRET=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
APP_BASE_URL=http://localhost:3000
